{
  "plugins": {
    "allow": ["claw-ops"],
    "entries": {
      "claw-ops": {
        "enabled": true,
        "hooks": {
          "allowPromptInjection": true
        },
        "config": {
          "baseUrl": "https://ops.pinglan.cc",
          "accessToken": "REPLACE_WITH_EDGEOPS_JWT_OR_eop_TOKEN",
          "appendOpenClawUiHints": true,
          "blockLocalEdgeOpsExec": true
        }
      }
    }
  },
  "tools": {
    "profile": "coding",
    "alsoAllow": ["claw-ops"]
  }
}
